---
import { about } from "../data/site";
---

<section id="about" class="mx-auto max-w-4xl scroll-mt-20 px-5 py-10">
  <h2 class="mb-4 text-sm font-semibold tracking-widest text-indigo-600 uppercase dark:text-indigo-400">
    About
  </h2>
  <div class="space-y-4 text-base leading-relaxed text-zinc-700 dark:text-zinc-300">
    {about.map((p) => <p>{p}</p>)}
  </div>
</section>
