---
import { publications } from "../data/publications";

const NAME = "Thang Duong";
---

<section id="publications" class="mx-auto max-w-4xl scroll-mt-20 px-5 py-10">
  <h2 class="mb-6 text-sm font-semibold tracking-widest text-indigo-600 uppercase dark:text-indigo-400">
    Publications
  </h2>

  <ol class="space-y-5">
    {
      publications.map((p) => {
        const parts = p.authors.split(NAME);
        return (
          <li class="border-l-2 border-zinc-200 pl-4 dark:border-zinc-800">
            <p class="font-medium text-zinc-900 dark:text-zinc-100">
              {p.title}
            </p>
            <p class="mt-0.5 text-sm text-zinc-600 dark:text-zinc-400">
              {parts.map((seg, i) => (
                <>
                  {seg}
                  {i < parts.length - 1 && (
                    <strong class="text-zinc-800 dark:text-zinc-200">{NAME}</strong>
                  )}
                </>
              ))}
            </p>
            <p class="mt-0.5 flex flex-wrap items-center gap-2 text-sm">
              <span class="italic text-zinc-500 dark:text-zinc-400">
                {p.venue}
                {!p.status && `, ${p.year}`}
              </span>
              {p.status === "under-review" && (
                <span class="rounded-full bg-amber-100 px-2 py-0.5 text-xs font-semibold text-amber-800 dark:bg-amber-950/60 dark:text-amber-300">
                  Under review
                </span>
              )}
              {(p.links ?? []).map((l) => (
                <a
                  href={l.url}
                  target={l.url.startsWith("http") ? "_blank" : undefined}
                  rel="noopener"
                  class="text-xs font-medium text-indigo-600 hover:underline dark:text-indigo-400"
                >
                  [{l.label}]
                </a>
              ))}
            </p>
          </li>
        );
      })
    }
  </ol>
</section>
