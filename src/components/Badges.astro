---
import { badges } from "../data/site";
---

<section class="mx-auto max-w-4xl px-5 pb-4">
  <div class="flex flex-wrap gap-2">
    {
      badges.map((b) => (
        <span class="inline-flex items-center gap-1.5 rounded-full border border-indigo-200 bg-indigo-50 px-3 py-1 text-sm font-medium text-indigo-700 dark:border-indigo-900 dark:bg-indigo-950/50 dark:text-indigo-300">
          <span class="h-1.5 w-1.5 rounded-full bg-indigo-500" />
          {b}
        </span>
      ))
    }
  </div>
</section>
