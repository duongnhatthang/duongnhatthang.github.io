---
import { research, bibtex } from "../data/site";
---

<section id="research" class="mx-auto max-w-4xl scroll-mt-20 px-5 py-10">
  <h2 class="mb-6 text-sm font-semibold tracking-widest text-indigo-600 uppercase dark:text-indigo-400">
    Selected Research
  </h2>

  <div class="space-y-6">
    {
      research.map((item) => {
        const normalLinks = (item.links ?? []).filter(
          (l) => l.label !== "BibTeX"
        );
        const hasBibtex = (item.links ?? []).some((l) => l.label === "BibTeX");
        return (
          <article class="rounded-xl border border-zinc-200 bg-zinc-50/50 p-5 transition-colors hover:border-indigo-300 dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-indigo-800">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              {item.status === "under-review" ? (
                <span class="rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-800 dark:bg-amber-950/60 dark:text-amber-300">
                  Working paper
                </span>
              ) : (
                <span class="rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-semibold text-emerald-800 dark:bg-emerald-950/60 dark:text-emerald-300">
                  Published
                </span>
              )}
              {item.venue && (
                <span class="text-xs font-medium text-zinc-500 dark:text-zinc-400">
                  {item.venue}
                </span>
              )}
            </div>

            <h3 class="text-lg leading-snug font-semibold text-zinc-900 dark:text-zinc-100">
              {item.title}
            </h3>
            <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
              {item.authorLine}
            </p>

            <p class="mt-3 border-l-2 border-indigo-500 pl-3 text-[15px] font-medium text-zinc-800 dark:text-zinc-200">
              {item.impact}
            </p>
            <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
              {item.blurb}
            </p>

            {item.figures && item.figures.length > 0 && (
              <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
                {item.figures.map((f) => (
                  <figure class="overflow-hidden rounded-lg border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-950">
                    <button
                      type="button"
                      class="fig-thumb block w-full"
                      data-src={f.src}
                      data-caption={f.caption}
                      aria-label={`Enlarge: ${f.caption}`}
                    >
                      <img
                        src={f.src}
                        alt={f.caption}
                        loading="lazy"
                        class="h-40 w-full bg-white object-contain p-2"
                      />
                    </button>
                    <figcaption class="border-t border-zinc-100 px-3 py-2 text-xs text-zinc-500 dark:border-zinc-800 dark:text-zinc-400">
                      {f.caption}
                    </figcaption>
                  </figure>
                ))}
              </div>
            )}

            {(normalLinks.length > 0 || hasBibtex) && (
              <div class="mt-4 flex flex-wrap items-center gap-2">
                {normalLinks.map((l) => (
                  <a
                    href={l.url}
                    target={l.url.startsWith("http") ? "_blank" : undefined}
                    rel="noopener"
                    class="rounded-md border border-zinc-300 px-2.5 py-1 text-xs font-medium text-zinc-700 transition-colors hover:border-indigo-500 hover:text-indigo-600 dark:border-zinc-700 dark:text-zinc-200 dark:hover:border-indigo-400 dark:hover:text-indigo-400"
                  >
                    {l.label}
                  </a>
                ))}
                {hasBibtex && (
                  <details class="group inline-block">
                    <summary class="cursor-pointer list-none rounded-md border border-zinc-300 px-2.5 py-1 text-xs font-medium text-zinc-700 transition-colors hover:border-indigo-500 hover:text-indigo-600 dark:border-zinc-700 dark:text-zinc-200 dark:hover:border-indigo-400 dark:hover:text-indigo-400">
                      BibTeX
                    </summary>
                    <div class="mt-2 w-full">
                      <pre class="overflow-x-auto rounded-lg bg-zinc-900 p-3 text-xs text-zinc-100 dark:bg-black">{bibtex.neurips24}</pre>
                      <button
                        type="button"
                        class="copy-bibtex mt-1 text-xs text-indigo-600 hover:underline dark:text-indigo-400"
                      >
                        Copy
                      </button>
                    </div>
                  </details>
                )}
              </div>
            )}
          </article>
        );
      })
    }
  </div>
</section>

<!-- Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-6"
>
  <figure class="max-h-full max-w-3xl text-center">
    <img id="lightbox-img" src="" alt="" class="mx-auto max-h-[80vh] rounded-lg bg-white object-contain" />
    <figcaption id="lightbox-cap" class="mt-3 text-sm text-zinc-200"></figcaption>
  </figure>
</div>

<script>
  // Lightbox
  const lb = document.getElementById("lightbox");
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
  const lbCap = document.getElementById("lightbox-cap");
  document.querySelectorAll<HTMLButtonElement>(".fig-thumb").forEach((btn) => {
    btn.addEventListener("click", () => {
      if (!lb || !lbImg) return;
      lbImg.src = btn.dataset.src ?? "";
      lbImg.alt = btn.dataset.caption ?? "";
      if (lbCap) lbCap.textContent = btn.dataset.caption ?? "";
      lb.classList.remove("hidden");
      lb.classList.add("flex");
    });
  });
  lb?.addEventListener("click", () => {
    lb.classList.add("hidden");
    lb.classList.remove("flex");
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lb && !lb.classList.contains("hidden")) {
      lb.classList.add("hidden");
      lb.classList.remove("flex");
    }
  });

  // Copy BibTeX
  document.querySelectorAll<HTMLButtonElement>(".copy-bibtex").forEach((b) => {
    b.addEventListener("click", () => {
      const pre = b.parentElement?.querySelector("pre");
      if (pre) {
        navigator.clipboard.writeText(pre.textContent ?? "");
        const prev = b.textContent;
        b.textContent = "Copied!";
        setTimeout(() => (b.textContent = prev), 1500);
      }
    });
  });
</script>
